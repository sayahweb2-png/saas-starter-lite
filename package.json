{
  "name": "saas-starter-lite",
  "version": "1.0.0",
  "license": "MIT",
  "description": "Free NestJS + Angular auth boilerplate. The lite version of SaaS Starter.",
  "scripts": {
    "dev": "npx nx run-many --target=serve --projects=api,web --parallel=2",
    "dev:api": "npx nx serve api",
    "dev:web": "npx nx serve web",
    "build": "npx nx run-many --target=build --projects=api,web",
    "build:api": "npx nx build api --configuration=production",
    "build:web": "npx nx build web --configuration=production",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@angular/animations": "^21.2.13",
    "@angular/common": "~21.2.0",
    "@angular/compiler": "~21.2.0",
    "@angular/core": "~21.2.0",
    "@angular/forms": "~21.2.0",
    "@angular/platform-browser": "~21.2.0",
    "@angular/platform-server": "~21.2.0",
    "@angular/router": "~21.2.0",
    "@angular/ssr": "~21.2.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.4.3",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "express": "^4.22.2",
    "helmet": "^8.1.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.21.0",
    "postcss": "^8.5.15",
    "reflect-metadata": "^0.1.13",
    "resend": "^6.12.3",
    "rxjs": "^7.8.0",
    "swagger-ui-express": "^5.0.1",
    "tailwindcss": "^4.3.0",
    "typeorm": "^0.3.30",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@angular-devkit/core": "~21.2.0",
    "@angular-devkit/schematics": "~21.2.0",
    "@angular/build": "~21.2.0",
    "@angular/cli": "~21.2.0",
    "@angular/compiler-cli": "~21.2.0",
    "@nx/angular": "^22.7.2",
    "@nx/devkit": "22.7.2",
    "@nx/js": "22.7.2",
    "@nx/node": "22.7.2",
    "@nx/web": "22.7.2",
    "@nx/webpack": "22.7.2",
    "@schematics/angular": "~21.2.0",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/node": "20.19.9",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
