# ===========================================
# SaaS Starter Lite — Environment Variables
# ===========================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Want Stripe, Redis, S3, and more? Get the full version:
#   https://demo.cloudrix.io

# --- Required ---
# Generate secrets with: openssl rand -base64 32
JWT_SECRET=change-me-generate-with-openssl-rand-base64-32
JWT_REFRESH_SECRET=change-me-generate-with-openssl-rand-base64-32

# Database (matches docker-compose.yml defaults)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=saas_lite_db
DB_SYNCHRONIZE=true

# --- Optional ---
# Frontend URL (for email links)
FRONTEND_URL=http://localhost:4200

# Google OAuth (leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# Email (Resend.com — leave empty for console logging)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com
APP_NAME=SaaS Starter Lite
